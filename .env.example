# ── Backend Environment Variables ──

# Server port
PORT=5000

# Application metadata
APP_NAME="XelCo Smart Waste Management"
APP_ENV="development"

# JWT Configuration
SECRET_KEY="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="30"

# Supabase Backend Service Role (Required for Auth Backend to bypass RLS)
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key-do-not-expose-to-frontend"

# Gmail SMTP (for OTP verification emails)
GMAIL_USER="your_email@gmail.com"
GMAIL_APP_PASSWORD="your_app_password"

# OTP Expiry
OTP_EXPIRE_MINUTES="10"

# ── Frontend Environment Variables (VITE_ prefix) ──

# Backend API URL (used in production frontend builds)
VITE_API_URL=http://localhost:5000/api

# Supabase (for SmartBin real-time data)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
